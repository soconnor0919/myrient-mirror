<?xml version="1.0"?>
<Container version="2">
  <Name>myrient-mirror</Name>
  <Repository>ghcr.io/soconnor0919/myrient-mirror:latest</Repository>
  <Registry>https://github.com/soconnor0919/myrient-mirror/pkgs/container/myrient-mirror</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/soconnor0919/myrient-mirror/issues</Support>
  <Project>https://github.com/soconnor0919/myrient-mirror</Project>
  <Overview>Modern Download Manager for Myrient (with AriaNg Web UI).</Overview>
  <Category>Backup: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8267]</WebUI>
  <Icon>https://cdn-icons-png.flaticon.com/512/566/566311.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <Description>Modern Download Manager for Myrient (with AriaNg Web UI).</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8267</HostPort>
        <ContainerPort>8267</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>6800</HostPort>
        <ContainerPort>6800</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/data/backups/nintendo</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>NES,SNES,GB,GBC,GBA,DS,GC,WII</Value>
      <Name>SYNC_SYSTEMS</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>.*\(USA\).*</Value>
      <Name>REGION_FILTER</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="8267" Default="8267" Mode="tcp" Description="AriaNg Web Interface" Type="Port" Display="always" Required="true" Mask="false">8267</Config>
  <Config Name="RPC Port" Target="6800" Default="6800" Mode="tcp" Description="Aria2 RPC Port" Type="Port" Display="always" Required="true" Mask="false">6800</Config>
  <Config Name="Backup Path" Target="/data" Default="/mnt/user/data/backups/nintendo" Mode="rw" Description="Path where mirrored files will be stored" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/data/backups/nintendo</Config>
  <Config Name="Systems to Sync" Target="SYNC_SYSTEMS" Default="NES,SNES,GB,GBC,GBA,DS,GC,WII" Mode="" Description="Comma separated list of systems" Type="Variable" Display="always" Required="false" Mask="false">NES,SNES,GB,GBC,GBA,DS,GC,WII</Config>
</Container>
